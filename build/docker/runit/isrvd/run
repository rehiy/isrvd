#!/bin/bash
exec 2>&1

# 等待 APISIX Control API 就绪（无需 admin key，9090 端口）
echo "[isrvd] Waiting for APISIX..."
for i in $(seq 1 60); do
    if curl -sf --connect-timeout 2 --max-time 5 http://127.0.0.1:9090/v1/healthcheck &>/dev/null; then
        echo "[isrvd] APISIX is ready"
        break
    fi
    if [ "$i" -eq 60 ]; then
        echo "[isrvd] APISIX not ready after 60s, continuing anyway..."
        break
    fi
    sleep 1
done

echo "[isrvd] Starting isrvd..."
cd /data

echo "[isrvd] Using CONFIG_PATH: $CONFIG_PATH"
exec /usr/local/bin/isrvd
