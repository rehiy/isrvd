#!/bin/bash
exec 2>&1

# 等待 APISIX Control API 就绪（9090 端口）
# 使用 bash 内置 /dev/tcp，不依赖 curl/wget
echo "[isrvd] Waiting for APISIX..."
for i in $(seq 1 60); do
    if bash -c "echo > /dev/tcp/127.0.0.1/9090" 2>/dev/null; then
        echo "[isrvd] APISIX is ready (${i}s)"
        break
    fi
    [ "$i" -eq 60 ] && echo "[isrvd] APISIX not ready after 60s, continuing anyway..."
    sleep 1
done

echo "[isrvd] Starting isrvd..."
cd /data
echo "[isrvd] Using CONFIG_PATH: $CONFIG_PATH"
exec /usr/local/bin/isrvd
